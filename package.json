{
  "name": "vuepoint",
  "version": "0.0.3",
  "description": "Visual feedback overlay for Vue and Nuxt apps.",
  "type": "module",
  "license": "MIT",
  "keywords": [
    "vue",
    "nuxt",
    "feedback",
    "annotations",
    "developer-tools",
    "vite"
  ],
  "files": [
    "dist"
  ],
  "main": "./dist/vuepoint.cjs",
  "module": "./dist/vuepoint.js",
  "types": "./dist/index.d.ts",
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/vuepoint.js",
      "require": "./dist/vuepoint.cjs"
    },
    "./vite": {
      "types": "./dist/vite.d.ts",
      "import": "./dist/vite.js",
      "require": "./dist/vite.cjs"
    },
    "./style.css": "./dist/style.css"
  },
  "sideEffects": [
    "./dist/style.css"
  ],
  "scripts": {
    "dev": "vite",
    "build": "vue-tsc --noEmit && vite build",
    "test": "npm run test:unit && npm run test:package",
    "test:package": "npm run build && node --test tests/package-types.test.mjs",
    "test:unit": "vue-tsc --noEmit && vite build --config vite.testing.config.ts && node --test tests/copy-depth.test.mjs tests/enabled.test.mjs tests/storage.test.mjs tests/vite.test.mjs",
    "typecheck": "vue-tsc --noEmit",
    "preview": "vite preview"
  },
  "peerDependencies": {
    "vite": "^7.0.0",
    "vue": "^3.5.0"
  },
  "dependencies": {
    "@vue/compiler-dom": "^3.5.30",
    "@vue/compiler-sfc": "^3.5.30"
  },
  "devDependencies": {
    "@vitejs/plugin-vue": "^6.0.1",
    "typescript": "^5.9.3",
    "vite": "^7.1.7",
    "vite-plugin-dts": "^4.5.4",
    "vue": "^3.5.18",
    "vue-tsc": "^3.0.5"
  }
}
